rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && 
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
         (request.auth.token.email == "datingwithbounce@gmail.com" || request.auth.token.email == "raymondsurv@gmail.com"));
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidLiveStream(data) {
      return data.title is string && data.title.size() <= 100 &&
             data.category is string && data.category.size() <= 50 &&
             data.streamerId == request.auth.uid &&
             data.streamerName is string && data.streamerName.size() <= 100 &&
             data.status in ['live', 'ended'] &&
             data.createdAt == request.time;
    }

    function isValidLiveComment(data) {
      return data.text is string && data.text.size() <= 500 &&
             data.user is string && data.userId == request.auth.uid &&
             data.createdAt == request.time;
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if (isOwner(userId) || isAdmin());
      allow update: if isOwner(userId) 
                    || isAdmin() 
                    || (userId.matches('^fake_.*') && isSignedIn());
      allow delete: if isAdmin();
    }

    match /messages/{messageId} {
      allow read: if isSignedIn() && (
        (resource == null) || 
        (resource.data.senderId == request.auth.uid || resource.data.receiverId == request.auth.uid)
      );
      allow create: if isSignedIn() && (
        (request.auth.uid == incoming().senderId) ||
        (incoming().senderId.matches('^fake_.*'))
      );
      allow update: if isSignedIn() && (
        (request.auth.uid == resource.data.receiverId) ||
        (request.auth.uid == resource.data.senderId) ||
        isAdmin()
      );
      allow delete: if isSignedIn() && (request.auth.uid == resource.data.senderId || isAdmin());
    }

    match /posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn() && (request.auth.uid == resource.data.authorId || isAdmin());

      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        allow update: if isSignedIn() && (request.auth.uid == resource.data.authorId || isAdmin());
        allow delete: if isSignedIn() && (request.auth.uid == resource.data.authorId || isAdmin());
      }
    }

    match /live_streams/{streamId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn();
      
      allow create: if isSignedIn() && isValidLiveStream(incoming()) && 
                    incoming().keys().hasAll(['title', 'category', 'streamerId', 'streamerName', 'streamerPhoto', 'viewers', 'status', 'createdAt']) &&
                    incoming().keys().size() == 8;

      allow update: if (isOwner(existing().streamerId) || isAdmin()) &&
                    (incoming().status != 'live' || existing().status == 'live') &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['status', 'viewers', 'streamerPhoto', 'title', 'category']) &&
                    incoming().streamerId == existing().streamerId;
      
      allow delete: if isOwner(existing().streamerId) || isAdmin();

      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && isValidLiveComment(incoming()) &&
                      exists(/databases/$(database)/documents/live_streams/$(streamId));
        allow delete: if isAdmin() || (isSignedIn() && get(/databases/$(database)/documents/live_streams/$(streamId)).data.streamerId == request.auth.uid);
      }
    }

    match /notifications/{notificationId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /transactions/{txId} {
      allow read, write: if isSignedIn();
    }

    match /appConfig/{configId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /sponsoredContent/{adId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /movies/{movieId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
  }
}
