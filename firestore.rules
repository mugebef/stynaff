rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && 
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
         ((request.auth.token.email == "datingwithbounce@gmail.com" || request.auth.token.email == "raymondsurv@gmail.com") && request.auth.token.email_verified == true));
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if (isOwner(userId) || isAdmin());
      allow update: if isOwner(userId) 
                    || isAdmin() 
                    || (userId.startsWith('fake_') && isSignedIn()); // Allow anyone signed in to update AI status (typing indicator)
      allow delete: if isAdmin();
    }

    match /messages/{messageId} {
      // Expanded read access to support collection queries
      allow read: if isSignedIn() && (
        (resource == null) || 
        (resource.data.senderId == request.auth.uid || resource.data.receiverId == request.auth.uid)
      );
      
      // Allow create if sender is self OR if sender is a fake profile (AI response simulation)
      allow create: if isSignedIn() && (
        (request.auth.uid == incoming().senderId) ||
        (incoming().senderId.startsWith('fake_'))
      );
      
      // Allow update for status/read receipts
      allow update: if isSignedIn() && (
        (request.auth.uid == resource.data.receiverId) ||
        (request.auth.uid == resource.data.senderId) ||
        isAdmin()
      );
      
      allow delete: if isSignedIn() && (request.auth.uid == resource.data.senderId || isAdmin());
    }

    match /posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn() && (request.auth.uid == resource.data.authorId || isAdmin());

      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        allow update: if isSignedIn() && (request.auth.uid == resource.data.authorId || isAdmin());
        allow delete: if isSignedIn() && (request.auth.uid == resource.data.authorId || isAdmin());
      }
    }

    match /notifications/{notificationId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /transactions/{txId} {
      allow read, write: if isSignedIn();
    }

    match /appConfig/{configId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /sponsoredContent/{adId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /movies/{movieId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
  }
}
