rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required) - Unique user ID
    //   - displayName: string (required) - User's display name
    //   - email: string (required) - User's email address
    //   - photoURL: string (optional) - URL to user's profile photo
    //   - role: string (required, 'user'|'admin') - User's role
    //   - bio: string (optional) - User's biography
    //   - friends: list (required) - List of friend UIDs
    //   - friendRequests: list (required) - List of incoming friend request UIDs
    //
    // Collection: posts
    // Document ID: {postId}
    // Fields:
    //   - id: string (required) - Unique post ID
    //   - authorId: string (required) - UID of the post author
    //   - authorName: string (required) - Name of the post author
    //   - authorPhoto: string (optional) - Photo URL of the post author
    //   - content: string (required) - Text content of the post
    //   - mediaUrl: string (optional) - URL to attached photo or video
    //   - mediaType: string (optional, 'image'|'video') - Type of attached media
    //   - createdAt: timestamp (required) - Timestamp when the post was created
    //   - likes: list (required) - List of UIDs who liked the post
    //
    // Collection: posts/{postId}/comments
    // Document ID: {commentId}
    // Fields:
    //   - id: string (required) - Unique comment ID
    //   - postId: string (required) - ID of the parent post
    //   - authorId: string (required) - UID of the comment author
    //   - authorName: string (required) - Name of the comment author
    //   - content: string (required) - Text content of the comment
    //   - createdAt: timestamp (required) - Timestamp when the comment was created
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "datingwithbounce@gmail.com" && request.auth.token.email_verified == true));
    }
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName', 'email', 'role', 'friends', 'friendRequests', 'tier', 'isVerified', 'verificationRequested', 'walletBalance', 'points', 'profileViews', 'createdAt']) &&
             data.uid is string && data.uid.size() > 0 &&
             data.displayName is string && data.displayName.size() > 0 &&
             data.email is string &&
             data.role in ['user', 'admin'] &&
             data.tier in ['General', 'Bronze', 'Silver', 'Gold', 'Platinum'] &&
             data.isVerified is bool &&
             data.verificationRequested is bool &&
             data.friends is list &&
             data.friendRequests is list &&
             data.walletBalance is number &&
             data.points is number &&
             data.profileViews is number &&
             data.createdAt is timestamp;
    }
    function isValidPost(data) {
      return data.keys().hasAll(['authorId', 'authorName', 'content', 'createdAt', 'likes', 'shares']) &&
             data.authorId is string &&
             data.authorName is string &&
             data.content is string &&
             data.createdAt is timestamp &&
             data.likes is list &&
             data.shares is number &&
             (!('authorPhoto' in data) || data.authorPhoto == null || data.authorPhoto is string) &&
             (!('authorVerified' in data) || data.authorVerified is bool) &&
             (!('mediaUrl' in data) || data.mediaUrl == null || data.mediaUrl is string) &&
             (!('mediaType' in data) || data.mediaType == null || data.mediaType is string) &&
             (!('isReel' in data) || data.isReel is bool) &&
             (!('comments' in data) || data.comments is list) &&
             (!('isSponsored' in data) || data.isSponsored is bool);
    }
    function isValidAd(data) {
      return data.keys().hasAll(['title', 'description', 'imageUrl', 'link', 'active', 'createdAt']) &&
             data.title is string &&
             data.description is string &&
             data.imageUrl is string &&
             data.link is string &&
             data.active is bool &&
             data.createdAt is timestamp;
    }
    function isValidPage(data) {
      return data.keys().hasAll(['name', 'description', 'ownerId', 'isVerified', 'followers', 'createdAt']) &&
             data.name is string && data.name.size() > 0 &&
             data.ownerId is string &&
             data.isVerified is bool &&
             data.followers is list &&
             data.createdAt is timestamp;
    }
    function isValidGroup(data) {
      return data.keys().hasAll(['name', 'description', 'ownerId', 'members', 'isPrivate', 'createdAt']) &&
             data.name is string && data.name.size() > 0 &&
             data.ownerId is string &&
             data.members is list &&
             data.isPrivate is bool &&
             data.createdAt is timestamp;
    }
    function isValidComment(data) {
      return data.keys().hasAll(['authorId', 'authorName', 'content', 'createdAt']) &&
             data.authorId is string &&
             data.authorName is string &&
             data.content is string &&
             data.createdAt is timestamp;
    }
    function isValidMessage(data) {
      return data.keys().hasAll(['senderId', 'receiverId', 'content', 'createdAt', 'read']) &&
             data.senderId is string &&
             data.receiverId is string &&
             data.content is string &&
             data.createdAt is timestamp &&
             data.read is bool;
    }
    function isValidStatus(data) {
      return data.keys().hasAll(['userId', 'userName', 'mediaUrl', 'mediaType', 'createdAt', 'expiresAt']) &&
             data.userId is string &&
             data.userName is string &&
             data.mediaUrl is string &&
             data.mediaType in ['image', 'video'] &&
             data.createdAt is timestamp &&
             data.expiresAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && (request.resource.data.role == 'user' || isAdmin());
      allow update: if (isOwner(userId) && (request.resource.data.role == resource.data.role || isAdmin())) || isAdmin();
      allow delete: if isAdmin();
    }

    match /posts/{postId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidPost(request.resource.data);
      allow update: if (isAuthenticated() && (
        (request.auth.uid == resource.data.authorId && isValidPost(request.resource.data)) ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'shares', 'isBoosted', 'boostBudget']))
      )) || isAdmin();
      allow delete: if (isAuthenticated() && request.auth.uid == resource.data.authorId) || isAdmin();

      match /comments/{commentId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && isValidComment(request.resource.data);
        allow update: if (isAuthenticated() && request.auth.uid == resource.data.authorId && isValidComment(request.resource.data)) || isAdmin();
        allow delete: if (isAuthenticated() && request.auth.uid == resource.data.authorId) || isAdmin();
      }
    }

    match /pages/{pageId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidPage(request.resource.data);
      allow update: if (isAuthenticated() && (
        (request.auth.uid == resource.data.ownerId && isValidPage(request.resource.data)) ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followers']))
      )) || isAdmin();
      allow delete: if (isAuthenticated() && request.auth.uid == resource.data.ownerId) || isAdmin();
    }

    match /groups/{groupId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidGroup(request.resource.data);
      allow update: if (isAuthenticated() && (
        (request.auth.uid == resource.data.ownerId && isValidGroup(request.resource.data)) ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members']))
      )) || isAdmin();
      allow delete: if (isAuthenticated() && request.auth.uid == resource.data.ownerId) || isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && request.auth.uid == resource.data.toId;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && request.auth.uid == resource.data.toId && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.toId;
    }

    match /transactions/{txId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.userId;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /appConfig/{configId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /messages/{messageId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.senderId || request.auth.uid == resource.data.receiverId);
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.senderId && isValidMessage(request.resource.data);
      allow update: if isAuthenticated() && request.auth.uid == resource.data.receiverId && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.senderId;
    }

    match /statuses/{statusId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.userId && isValidStatus(request.resource.data);
      allow delete: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
    }

    match /sponsoredContent/{adId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
